      "item": [
        {
          "name": "Register User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const response = pm.response.json();",
                  "",
                  "if (response.access_token) {",
                  "    pm.environment.set(\"accessToken\", response.access_token);",
                  "}",
                  "",
                  "if (response.refresh_token) {",
                  "    pm.environment.set(\"refreshToken\", response.refresh_token);",
                  "}",
                  "",
                  "if (response.verificationCode) {",
                  "    pm.environment.set(\"verificationCode\", response.verificationCode);",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"juan@gmail.com\",\n    \"password\": \"12345678\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
